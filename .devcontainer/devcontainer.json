{
  "name": "Playwright + Copilot",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "postCreateCommand": "npm install && npx playwright install --with-deps chromium",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-playwright.playwright",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
